    {
      "type": "pwa-chrome",
      "request": "launch",
      "name": "Open Natural Korea React app",
      "url": "http://127.0.0.1:5173/",
      "webRoot": "${workspaceFolder}/src",
      "preLaunchTask": "Start Vite dev server"
    }
  ]
}